# OpenSSL configuration for wildcard certificate generation
# Used by the deploy script to create a self-signed wildcard cert for *.lab.local

[req]
default_bits = 2048
prompt = no
default_md = sha256
distinguished_name = dn
req_extensions = v3_req

[dn]
CN = *.lab.local

[v3_req]
subjectAltName = @alt_names

[alt_names]
DNS.1 = *.lab.local
DNS.2 = lab.local
